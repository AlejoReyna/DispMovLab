rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Chat attachments path convention:
    // /conversations/{conversationId}/messages/{messageId}/{fileName}
    match /conversations/{conversationId}/messages/{messageId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*|video/.*|application/pdf');
      allow delete: if isAdmin();
    }
  }
}
