rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdminByClaim() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isAdminByProfile() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isAdmin() {
      return isAdminByClaim() || isAdminByProfile();
    }

    function isConversationParticipant(conversationId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/conversations/$(conversationId)/participants/$(request.auth.uid));
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.role == "user" &&
        request.resource.data.isActive == true;

      // End users can only update profile fields, never role flags.
      allow update: if isOwner(uid) &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.isActive == resource.data.isActive;

      allow update, delete: if isAdmin();
    }

    match /conversations/{conversationId} {
      allow read: if isConversationParticipant(conversationId) || isAdmin();
      allow create: if isSignedIn() &&
        request.resource.data.type in ["direct", "group"] &&
        request.resource.data.participantIds is list &&
        request.resource.data.participantIds.hasAny([request.auth.uid]) &&
        request.resource.data.participantIds.size() >= 2 &&
        request.resource.data.participantIds.size() <= 100;

      // Participants can update lightweight metadata only.
      allow update: if isConversationParticipant(conversationId) &&
        request.resource.data.participantIds == resource.data.participantIds &&
        request.resource.data.type == resource.data.type;

      allow delete: if isAdmin();

      match /participants/{uid} {
        allow read: if isConversationParticipant(conversationId) || isAdmin();
        allow create: if isConversationParticipant(conversationId) || isAdmin();
        allow update: if isOwner(uid) || isAdmin();
        allow delete: if isAdmin();
      }

      match /messages/{messageId} {
        allow read: if isConversationParticipant(conversationId) || isAdmin();
        allow create: if isConversationParticipant(conversationId) &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.text.size() <= 4000 &&
          request.resource.data.status == "sent";
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
    }

    match /reports/{reportId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.reporterUid);
      allow create: if isSignedIn() &&
        request.resource.data.reporterUid == request.auth.uid &&
        request.resource.data.state == "open";
      allow update, delete: if isAdmin();
    }
  }
}
